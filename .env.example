NODE_ENV=production
PORT=3000
# Canonical environment template for both compose.yaml and compose.app.yaml.
# Copy the immutable name@sha256 digest from the successful release workflow summary.
CODA_IMAGE=ghcr.io/kinetik-gg/coda@sha256:replace-with-release-manifest-digest
APP_ORIGIN=http://localhost:3000
# Used only by explicit localhost overrides.
CODA_BIND_ADDRESS=127.0.0.1
CODA_APP_PORT=3000
CODA_S3_BIND_ADDRESS=127.0.0.1
CODA_S3_PORT=9000
# Which peers may supply X-Forwarded-For. "auto" trusts the private subnets the
# platform attached to this container (derived at boot from its non-loopback
# interfaces and logged for auditability). For a hardened deployment, replace it
# with the exact reverse-proxy source IPs/CIDRs instead. Never mix "auto" with an
# explicit list, and never use an all-address CIDR such as 0.0.0.0/0 or ::/0.
TRUSTED_PROXY_CIDRS=auto
# Full-stack only: browser origins allowed to use signed MinIO URLs.
MINIO_CORS_ALLOW_ORIGIN=http://localhost:3000,http://localhost:5173
# Full-stack only. App-only deployments use the managed database URL below instead.
POSTGRES_PASSWORD=replace-with-a-long-random-password
# Keep this password in sync with POSTGRES_PASSWORD and URL-encode it when needed.
DATABASE_URL=postgresql://coda:replace-with-a-long-random-password@postgres:5432/coda?schema=public
# Managed PostgreSQL example (replace every component and require TLS):
# DATABASE_URL=postgresql://user:password@db.example.com:5432/coda?schema=public&sslmode=require&sslaccept=strict
SESSION_COOKIE_NAME=coda_session
SESSION_TTL_DAYS=30
# Encrypts the instance-configuration store (AES-256-GCM). Generate with
# `openssl rand -base64 32`. Keep it stable and back it up: the same key is
# required to read previously written config, and Coda refuses to start if
# encrypted config rows exist but the key is missing or wrong. Optional until a
# feature writes config; required from then on.
CONFIG_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
# Account-scoped progressive login backoff, in addition to per-IP throttling. After this many
# consecutive failed logins for one account, each further failure opens the next delay window
# (milliseconds; the final value is the cap). Cleared on a successful login or password reset.
AUTH_LOGIN_BACKOFF_THRESHOLD=5
AUTH_LOGIN_BACKOFF_WINDOWS_MS=60000,300000,900000
# SETUP_TOKEN is optional. Leave it unset and Coda generates a one-time setup
# token at first boot, printing it to the container logs (look for the
# "CODA SETUP TOKEN" banner) until owner setup completes. Set an explicit value
# (>=32 characters) to choose the token yourself; this is required when running
# more than one replica, since each replica would otherwise generate its own.
# SETUP_TOKEN=replace-with-a-long-random-one-time-setup-token
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=coda
# Full-stack only: MinIO bootstrap credentials are used by MinIO and its one-shot initializer.
MINIO_ROOT_USER=replace-with-a-random-root-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-root-password
MINIO_FORCE_OWNERSHIP_REPAIR=0
# Coda uses this bucket-scoped service account, never the MinIO root account.
S3_ACCESS_KEY=replace-with-a-random-service-access-key
S3_SECRET_KEY=replace-with-a-long-random-service-secret-key
S3_FORCE_PATH_STYLE=true
PDF_MAX_BYTES=262144000
PDF_WORKER_MAX_OLD_GENERATION_MB=512
# The transport limit covers 5,000,000 UTF-8 Fountain characters plus JSON overhead.
SCREENPLAY_REQUEST_MAX_BYTES=20016384
SCREENPLAY_BODY_MAX_CONCURRENT=4
SCREENPLAY_PREAUTH_WINDOW_MS=60000
SCREENPLAY_PREAUTH_MAX_PER_CLIENT=120
SCREENPLAY_PREAUTH_MAX_GLOBAL=1200
SCREENPLAY_BODY_TIMEOUT_MS=30000
SCREENPLAY_MAX_DOCUMENTS_PER_OWNER=250
SCREENPLAY_MAX_SOURCE_BYTES_PER_OWNER=262144000
ASSET_MAX_BYTES=2147483648
STORAGE_PENDING_MAX_OBJECTS=20
STORAGE_PENDING_MAX_BYTES=5368709120
STORAGE_PENDING_INSTANCE_MAX_OBJECTS=1000
STORAGE_PENDING_INSTANCE_MAX_BYTES=21474836480
STORAGE_UPLOAD_RETENTION_HOURS=24
SIGNED_READ_TTL_SECONDS=300
SIGNED_UPLOAD_TTL_SECONDS=900
LOG_LEVEL=info
# Opt-in HTTP error detail for staging diagnostics. When true, request-error log
# entries carry the sanitized error name, message, and HTTP status, plus a stack
# trace for 5xx responses. Request bodies, headers, cookies, tokens, and query
# strings are never logged in either mode. Leave false in production.
LOG_HTTP_ERROR_DETAIL=false
# Singleton job scheduler. Recurring jobs run exactly once across replicas via a Postgres
# advisory lock. SCHEDULER_JOB_TIMEOUT_MS bounds a single job tick. The optional heartbeat is a
# scheduler self-check; leave it disabled unless you want a liveness signal in the job registry.
SCHEDULER_JOB_TIMEOUT_MS=300000
SCHEDULER_HEARTBEAT_ENABLED=false
SCHEDULER_HEARTBEAT_INTERVAL_MS=3600000
# How often the scheduled-backup job wakes to check whether a backup is due. The effective
# cadence is the operator-configured interval (hours); this is only the polling granularity.
SCHEDULED_BACKUP_TICK_MS=3600000
# The destructive demo reset is opt-in and restricted to loopback services.
# Never set this in a shared or production environment.
# CODA_DEMO_RESET=true
# Hours between background checks for a newer Coda release, with startup jitter so a fleet of
# replicas restarting together does not poll at once. Set to 0 to disable polling entirely.
UPDATE_CHECK_INTERVAL_HOURS=24
# Pre-upgrade safety backup. When an initialized instance boots with pending database migrations,
# Coda writes an automatic signed archive to object storage under backups/pre-upgrade/ before the
# migrations run; boot aborts into the diagnostic page if that safety backup cannot be created.
# Requires CONFIG_ENCRYPTION_KEY (the archive signing key derives from it). Set to "off" to skip the
# safety backup and apply migrations unguarded — do this only when you have another fresh backup.
PRE_UPGRADE_BACKUP=on
# How many pre-upgrade archives to retain; older ones are pruned after a successful backup.
PRE_UPGRADE_BACKUP_KEEP=3
# METRICS_TOKEN is optional and unset by default, which disables the Prometheus /metrics
# endpoint entirely (it returns 404, not merely 401 unauthorized). Set an explicit value
# (>=16 characters) to enable it, then configure your scraper to send it as an
# `Authorization: Bearer <token>` header. See docs/operations.md for the metric inventory
# and a scrape config example.
# METRICS_TOKEN=replace-with-a-long-random-metrics-scrape-token
