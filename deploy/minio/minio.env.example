# Standalone object-storage stack for Coda. Copy to minio.env and replace every placeholder.
# This stack is deployed independently of the Coda application so storage keeps its own
# lifecycle. It defines no CODA_IMAGE, DATABASE_URL, or application variables.
# MinIO root credentials only bootstrap the bucket and the bucket-scoped service account;
# they are never handed to Coda. Coda receives only S3_ACCESS_KEY and S3_SECRET_KEY.
MINIO_ROOT_USER=replace-with-a-random-root-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-root-password
# Browser origins allowed to use signed MinIO URLs (the Coda APP_ORIGIN, plus dev origins).
MINIO_CORS_ALLOW_ORIGIN=http://localhost:3000,http://localhost:5173
# The stack performs its data-volume ownership migration once. After restoring the volume
# from a filesystem-level backup, set this to 1 for one deployment, confirm the object store
# is healthy, then return it to 0. Application-level bucket restores do not require this.
MINIO_FORCE_OWNERSHIP_REPAIR=0
# The private bucket and the bucket-scoped service account Coda authenticates with.
S3_BUCKET=coda
S3_ACCESS_KEY=replace-with-a-random-service-access-key
S3_SECRET_KEY=replace-with-a-long-random-service-secret-key
# Used only by the explicit localhost override.
CODA_S3_BIND_ADDRESS=127.0.0.1
CODA_S3_PORT=9000
