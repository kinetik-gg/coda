{
  "path": ["apps/api/src", "apps/web/src", "apps/mcp/src", "packages/contracts/src"],
  "format": ["typescript", "tsx"],
  "minLines": 10,
  "minTokens": 80,
  "threshold": 5,
  "reporters": ["console"],
  "ignore": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/generated/**",
    "**/dist/**",
    "**/coverage/**",
    "**/node_modules/**"
  ]
}
