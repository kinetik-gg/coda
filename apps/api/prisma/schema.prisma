generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum FieldType {
  TEXT
  LONG_TEXT
  ENUM
  MULTI_ENUM
  INTEGER
  FLOAT
  BOOLEAN
  DATE
  FILE
  IMAGE
  VIDEO
}

enum StorageKind {
  SOURCE_DOCUMENT
  FILE
  IMAGE
  VIDEO
}

enum StorageStatus {
  PENDING
  READY
  FAILED
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  RESTORED
  PURGED
  INVITED
  ACCEPTED
  TRANSFERRED
  COMMENTED
}

enum ApiCredentialKind {
  API_KEY
  MCP_TOKEN
}

model InstanceSettings {
  id            String   @id @default(uuid()) @db.Uuid
  ownerUserId   String   @unique @map("owner_user_id") @db.Uuid
  initializedAt DateTime @default(now()) @map("initialized_at") @db.Timestamptz(3)
  owner         User     @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)

  @@map("instance_settings")
}

model User {
  id                          String                         @id @default(uuid()) @db.Uuid
  email                       String                         @unique @db.Citext
  displayName                 String                         @map("display_name") @db.VarChar(120)
  company                     String?                        @db.VarChar(160)
  department                  String?                        @db.VarChar(120)
  theme                       String                         @default("coda-dark") @db.VarChar(40)
  fontSize                    String                         @default("default") @map("font_size") @db.VarChar(16)
  motionPreference            String                         @default("system") @map("motion_preference") @db.VarChar(16)
  pdfAppearance               String                         @default("theme") @map("pdf_appearance") @db.VarChar(16)
  passwordHash                String                         @map("password_hash")
  status                      UserStatus                     @default(ACTIVE)
  createdAt                   DateTime                       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                   DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(3)
  sessions                    Session[]
  ownedInstance               InstanceSettings?
  ownedProjects               Project[]                      @relation("ProjectOwner")
  ownedScreenplays            Screenplay[]                   @relation("ScreenplayOwner")
  screenplayRevisions         ScreenplayRevision[]           @relation("ScreenplayRevisionOwner")
  memberships                 ProjectMembership[]
  invitationsSent             ProjectInvitation[]            @relation("InvitationInviter")
  invitationsAccepted         ProjectInvitation[]            @relation("InvitationAcceptor")
  instanceInvitationsSent     InstanceInvitation[]           @relation("InstanceInvitationInviter")
  instanceInvitationsAccepted InstanceInvitation[]           @relation("InstanceInvitationAcceptor")
  bulkInvitationsRedeemed     InstanceInvitationRedemption[]
  resetTokens                 PasswordResetToken[]
  comments                    Comment[]
  activityEvents              ActivityEvent[]
  workspaceDefaultsPublished  ProjectWorkspaceDefault[]      @relation("WorkspaceDefaultPublisher")
  apiCredentials              ApiCredential[]                @relation("ApiCredentialOwner")
  apiCredentialsCreated       ApiCredential[]                @relation("ApiCredentialCreator")

  @@map("users")
}

model InstanceInvitation {
  id           String                         @id @default(uuid()) @db.Uuid
  email        String?                        @db.Citext
  isReusable   Boolean                        @default(false) @map("is_reusable")
  tokenHash    String                         @unique @map("token_hash") @db.Char(64)
  status       InvitationStatus               @default(PENDING)
  inviterId    String                         @map("inviter_id") @db.Uuid
  acceptedById String?                        @map("accepted_by_id") @db.Uuid
  projectId    String?                        @map("project_id") @db.Uuid
  roleId       String?                        @map("role_id") @db.Uuid
  expiresAt    DateTime?                      @map("expires_at") @db.Timestamptz(3)
  acceptedAt   DateTime?                      @map("accepted_at") @db.Timestamptz(3)
  revokedAt    DateTime?                      @map("revoked_at") @db.Timestamptz(3)
  createdAt    DateTime                       @default(now()) @map("created_at") @db.Timestamptz(3)
  inviter      User                           @relation("InstanceInvitationInviter", fields: [inviterId], references: [id], onDelete: Restrict)
  acceptedBy   User?                          @relation("InstanceInvitationAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)
  project      Project?                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role         ProjectRole?                   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  redemptions  InstanceInvitationRedemption[]

  @@index([status, createdAt])
  @@index([email, status])
  @@index([projectId, status])
  @@map("instance_invitations")
}

model InstanceInvitationRedemption {
  id           String             @id @default(uuid()) @db.Uuid
  invitationId String             @map("invitation_id") @db.Uuid
  userId       String             @map("user_id") @db.Uuid
  email        String             @db.Citext
  redeemedAt   DateTime           @default(now()) @map("redeemed_at") @db.Timestamptz(3)
  invitation   InstanceInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([invitationId, userId])
  @@unique([invitationId, email])
  @@index([invitationId, redeemedAt])
  @@map("instance_invitation_redemptions")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.Char(64)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("sessions")
}

model ApiCredential {
  id            String            @id @default(uuid()) @db.Uuid
  projectId     String            @map("project_id") @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  createdById   String?           @map("created_by_id") @db.Uuid
  kind          ApiCredentialKind
  name          String            @db.VarChar(120)
  tokenHash     String            @unique @map("token_hash") @db.Char(64)
  tokenPrefix   String            @map("token_prefix") @db.VarChar(32)
  tokenLastFour String            @map("token_last_four") @db.Char(4)
  permissions   String[]
  expiresAt     DateTime?         @map("expires_at") @db.Timestamptz(3)
  lastUsedAt    DateTime?         @map("last_used_at") @db.Timestamptz(3)
  revokedAt     DateTime?         @map("revoked_at") @db.Timestamptz(3)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User              @relation("ApiCredentialOwner", fields: [userId], references: [id], onDelete: Cascade)
  createdBy     User?             @relation("ApiCredentialCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([projectId, revokedAt, expiresAt])
  @@map("api_credentials")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.Char(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Project {
  id                  String                   @id @default(uuid()) @db.Uuid
  ownerUserId         String                   @map("owner_user_id") @db.Uuid
  name                String                   @db.VarChar(160)
  description         String?
  version             Int                      @default(1)
  revision            Int                      @default(1)
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt           DateTime?                @map("deleted_at") @db.Timestamptz(3)
  deletedById         String?                  @map("deleted_by_id") @db.Uuid
  deletionBatchId     String?                  @map("deletion_batch_id") @db.Uuid
  owner               User                     @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  memberships         ProjectMembership[]
  roles               ProjectRole[]
  invitations         ProjectInvitation[]
  entityTypes         EntityType[]
  items               BreakdownItem[]
  fields              FieldDefinition[]
  storageObjects      StorageObject[]
  sourceDocuments     SourceDocument[]
  comments            Comment[]
  activityEvents      ActivityEvent[]
  workspaceDefault    ProjectWorkspaceDefault?
  instanceInvitations InstanceInvitation[]
  apiCredentials      ApiCredential[]

  @@index([ownerUserId])
  @@index([deletedAt])
  @@map("projects")
}

model Screenplay {
  id               String               @id @default(uuid()) @db.Uuid
  ownerUserId      String               @map("owner_user_id") @db.Uuid
  title            String               @db.VarChar(160)
  filename         String               @db.VarChar(255)
  sourceText       String               @default("") @map("source_text")
  sourceByteLength Int                  @default(0) @map("source_byte_length")
  paperSize        String               @default("letter") @map("paper_size") @db.VarChar(16)
  version          Int                  @default(1)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  owner            User                 @relation("ScreenplayOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  revisions        ScreenplayRevision[]

  @@unique([id, ownerUserId])
  @@index([ownerUserId, updatedAt])
  @@map("screenplays")
}

model ScreenplayRevision {
  id                String     @id @default(uuid()) @db.Uuid
  screenplayId      String     @map("screenplay_id") @db.Uuid
  ownerUserId       String     @map("owner_user_id") @db.Uuid
  screenplayVersion Int        @map("screenplay_version")
  filename          String     @db.VarChar(255)
  sourceText        String     @map("source_text")
  sourceByteLength  Int        @map("source_byte_length")
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  screenplay        Screenplay @relation(fields: [screenplayId, ownerUserId], references: [id, ownerUserId], onDelete: Cascade)
  owner             User       @relation("ScreenplayRevisionOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  @@unique([screenplayId, screenplayVersion])
  @@index([ownerUserId, createdAt])
  @@index([screenplayId, createdAt])
  @@map("screenplay_revisions")
}

model ProjectRole {
  id                  String                  @id @default(uuid()) @db.Uuid
  projectId           String                  @map("project_id") @db.Uuid
  name                String                  @db.VarChar(80)
  description         String?                 @db.VarChar(500)
  isOwner             Boolean                 @default(false) @map("is_owner")
  position            String                  @db.VarChar(64)
  archivedAt          DateTime?               @map("archived_at") @db.Timestamptz(3)
  version             Int                     @default(1)
  project             Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  permissions         ProjectRolePermission[]
  memberships         ProjectMembership[]
  invitations         ProjectInvitation[]
  instanceInvitations InstanceInvitation[]

  @@unique([projectId, name])
  @@index([projectId, position])
  @@map("project_roles")
}

model ProjectRolePermission {
  id         String      @id @default(uuid()) @db.Uuid
  roleId     String      @map("role_id") @db.Uuid
  permission String      @db.VarChar(64)
  role       ProjectRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
  @@map("project_role_permissions")
}

model ProjectMembership {
  id              String                            @id @default(uuid()) @db.Uuid
  projectId       String                            @map("project_id") @db.Uuid
  userId          String                            @map("user_id") @db.Uuid
  roleId          String                            @map("role_id") @db.Uuid
  version         Int                               @default(1)
  createdAt       DateTime                          @default(now()) @map("created_at") @db.Timestamptz(3)
  project         Project                           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User                              @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            ProjectRole                       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  workspaceLayout ProjectMembershipWorkspaceLayout?

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_memberships")
}

model ProjectWorkspaceDefault {
  projectId     String   @id @map("project_id") @db.Uuid
  layout        Json     @db.JsonB
  schemaVersion Int      @map("schema_version")
  revision      Int      @default(0)
  publishedById String?  @map("published_by_id") @db.Uuid
  publishedAt   DateTime @map("published_at") @db.Timestamptz(3)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  publishedBy   User?    @relation("WorkspaceDefaultPublisher", fields: [publishedById], references: [id], onDelete: SetNull)

  @@index([publishedById])
  @@map("project_workspace_defaults")
}

model ProjectMembershipWorkspaceLayout {
  membershipId           String            @id @map("membership_id") @db.Uuid
  layout                 Json              @db.JsonB
  schemaVersion          Int               @map("schema_version")
  basedOnDefaultRevision Int               @map("based_on_default_revision")
  revision               Int               @default(0)
  createdAt              DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)
  membership             ProjectMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@map("project_membership_workspace_layouts")
}

model ProjectInvitation {
  id           String           @id @default(uuid()) @db.Uuid
  projectId    String           @map("project_id") @db.Uuid
  roleId       String           @map("role_id") @db.Uuid
  email        String           @db.Citext
  tokenHash    String           @unique @map("token_hash") @db.Char(64)
  status       InvitationStatus @default(PENDING)
  inviterId    String           @map("inviter_id") @db.Uuid
  acceptedById String?          @map("accepted_by_id") @db.Uuid
  expiresAt    DateTime         @map("expires_at") @db.Timestamptz(3)
  acceptedAt   DateTime?        @map("accepted_at") @db.Timestamptz(3)
  revokedAt    DateTime?        @map("revoked_at") @db.Timestamptz(3)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role         ProjectRole      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  inviter      User             @relation("InvitationInviter", fields: [inviterId], references: [id], onDelete: Restrict)
  acceptedBy   User?            @relation("InvitationAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@map("project_invitations")
}

model EntityType {
  id            String            @id @default(uuid()) @db.Uuid
  projectId     String            @map("project_id") @db.Uuid
  parentTypeId  String?           @map("parent_type_id") @db.Uuid
  singularName  String            @map("singular_name") @db.VarChar(80)
  pluralName    String            @map("plural_name") @db.VarChar(80)
  displayPrefix String?           @map("display_prefix") @db.VarChar(20)
  level         Int
  position      String            @db.VarChar(64)
  enabled       Boolean           @default(true)
  version       Int               @default(1)
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentType    EntityType?       @relation("EntityTypeHierarchy", fields: [parentTypeId], references: [id], onDelete: Restrict)
  childTypes    EntityType[]      @relation("EntityTypeHierarchy")
  items         BreakdownItem[]
  fields        FieldDefinition[]

  @@unique([projectId, level])
  @@index([projectId, position])
  @@map("entity_types")
}

model BreakdownItem {
  id               String                @id @default(uuid()) @db.Uuid
  projectId        String                @map("project_id") @db.Uuid
  entityTypeId     String                @map("entity_type_id") @db.Uuid
  parentId         String?               @map("parent_id") @db.Uuid
  title            String                @db.VarChar(300)
  displayCode      String?               @map("display_code") @db.VarChar(80)
  description      String?
  position         String                @db.VarChar(64)
  version          Int                   @default(1)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt        DateTime?             @map("deleted_at") @db.Timestamptz(3)
  deletedById      String?               @map("deleted_by_id") @db.Uuid
  deletionBatchId  String?               @map("deletion_batch_id") @db.Uuid
  project          Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entityType       EntityType            @relation(fields: [entityTypeId], references: [id], onDelete: Restrict)
  parent           BreakdownItem?        @relation("ItemHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children         BreakdownItem[]       @relation("ItemHierarchy")
  values           FieldValue[]
  sourceReferences ItemSourceReference[]
  comments         Comment[]

  @@index([projectId, entityTypeId, parentId, deletedAt, position])
  @@index([projectId, updatedAt])
  @@map("breakdown_items")
}

model FieldDefinition {
  id              String        @id @default(uuid()) @db.Uuid
  projectId       String        @map("project_id") @db.Uuid
  entityTypeId    String        @map("entity_type_id") @db.Uuid
  name            String        @db.VarChar(120)
  key             String        @db.VarChar(64)
  type            FieldType
  required        Boolean       @default(false)
  position        String        @db.VarChar(64)
  configuration   Json          @default("{}")
  version         Int           @default(1)
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(3)
  deletedById     String?       @map("deleted_by_id") @db.Uuid
  deletionBatchId String?       @map("deletion_batch_id") @db.Uuid
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entityType      EntityType    @relation(fields: [entityTypeId], references: [id], onDelete: Restrict)
  options         FieldOption[]
  values          FieldValue[]

  @@unique([entityTypeId, key])
  @@index([entityTypeId, deletedAt, position])
  @@map("field_definitions")
}

model FieldOption {
  id           String             @id @default(uuid()) @db.Uuid
  fieldId      String             @map("field_id") @db.Uuid
  label        String             @db.VarChar(120)
  color        String?            @db.VarChar(32)
  position     String             @db.VarChar(64)
  archivedAt   DateTime?          @map("archived_at") @db.Timestamptz(3)
  field        FieldDefinition    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  singleValues FieldValue[]       @relation("SingleEnumValue")
  multiValues  FieldValueOption[]

  @@index([fieldId, position])
  @@map("field_options")
}

model FieldValue {
  id              String             @id @default(uuid()) @db.Uuid
  itemId          String             @map("item_id") @db.Uuid
  fieldId         String             @map("field_id") @db.Uuid
  textValue       String?            @map("text_value")
  integerValue    Int?               @map("integer_value")
  floatValue      Float?             @map("float_value")
  booleanValue    Boolean?           @map("boolean_value")
  dateValue       DateTime?          @map("date_value") @db.Date
  optionId        String?            @map("option_id") @db.Uuid
  storageObjectId String?            @map("storage_object_id") @db.Uuid
  item            BreakdownItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  field           FieldDefinition    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  option          FieldOption?       @relation("SingleEnumValue", fields: [optionId], references: [id], onDelete: Restrict)
  storageObject   StorageObject?     @relation(fields: [storageObjectId], references: [id], onDelete: Restrict)
  options         FieldValueOption[]

  @@unique([itemId, fieldId])
  @@index([fieldId])
  @@index([fieldId, integerValue])
  @@index([fieldId, floatValue])
  @@index([fieldId, booleanValue])
  @@index([fieldId, dateValue])
  @@map("field_values")
}

model FieldValueOption {
  fieldValueId String      @map("field_value_id") @db.Uuid
  optionId     String      @map("option_id") @db.Uuid
  fieldValue   FieldValue  @relation(fields: [fieldValueId], references: [id], onDelete: Cascade)
  option       FieldOption @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@id([fieldValueId, optionId])
  @@map("field_value_options")
}

model StorageObject {
  id               String          @id @default(uuid()) @db.Uuid
  projectId        String          @map("project_id") @db.Uuid
  kind             StorageKind
  status           StorageStatus   @default(PENDING)
  objectKey        String          @unique @map("object_key")
  originalFilename String          @map("original_filename") @db.VarChar(255)
  mimeType         String          @map("mime_type") @db.VarChar(255)
  sizeBytes        BigInt          @map("size_bytes")
  width            Int?
  height           Int?
  durationMs       Int?            @map("duration_ms")
  version          Int             @default(1)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt        DateTime?       @map("deleted_at") @db.Timestamptz(3)
  deletedById      String?         @map("deleted_by_id") @db.Uuid
  deletionBatchId  String?         @map("deletion_batch_id") @db.Uuid
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceDocument   SourceDocument?
  fieldValues      FieldValue[]

  @@index([projectId, deletedAt, createdAt])
  @@map("storage_objects")
}

model StorageDeletionJob {
  id         String    @id @default(uuid()) @db.Uuid
  projectId  String    @map("project_id") @db.Uuid
  objectKey  String    @unique @map("object_key")
  attempts   Int       @default(0)
  lastError  String?   @map("last_error")
  notBefore  DateTime  @default(dbgenerated("(CURRENT_TIMESTAMP + '01:00:01'::interval)")) @map("not_before") @db.Timestamptz(3)
  claimToken String?   @map("claim_token") @db.Uuid
  claimedAt  DateTime? @map("claimed_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([createdAt])
  @@index([notBefore, claimedAt, createdAt])
  @@index([projectId])
  @@map("storage_deletion_jobs")
}

model SourceDocument {
  id              String                @id @default(uuid()) @db.Uuid
  projectId       String                @map("project_id") @db.Uuid
  storageObjectId String                @unique @map("storage_object_id") @db.Uuid
  title           String                @db.VarChar(255)
  pageCount       Int?                  @map("page_count")
  version         Int                   @default(1)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt       DateTime?             @map("deleted_at") @db.Timestamptz(3)
  deletedById     String?               @map("deleted_by_id") @db.Uuid
  deletionBatchId String?               @map("deletion_batch_id") @db.Uuid
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  storageObject   StorageObject         @relation(fields: [storageObjectId], references: [id], onDelete: Restrict)
  references      ItemSourceReference[]

  @@index([projectId, deletedAt])
  @@map("source_documents")
}

model ItemSourceReference {
  id               String         @id @default(uuid()) @db.Uuid
  itemId           String         @map("item_id") @db.Uuid
  sourceDocumentId String         @map("source_document_id") @db.Uuid
  startPage        Int            @map("start_page")
  endPage          Int            @map("end_page")
  position         String         @db.VarChar(64)
  item             BreakdownItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  sourceDocument   SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Restrict)

  @@index([itemId, position])
  @@map("item_source_references")
}

model Comment {
  id        String        @id @default(uuid()) @db.Uuid
  projectId String        @map("project_id") @db.Uuid
  itemId    String        @map("item_id") @db.Uuid
  authorId  String        @map("author_id") @db.Uuid
  body      String
  version   Int           @default(1)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt DateTime?     @map("deleted_at") @db.Timestamptz(3)
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  item      BreakdownItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([itemId, deletedAt, createdAt])
  @@map("comments")
}

model ActivityEvent {
  id           String         @id @default(uuid()) @db.Uuid
  projectId    String         @map("project_id") @db.Uuid
  actorId      String?        @map("actor_id") @db.Uuid
  action       ActivityAction
  resourceType String         @map("resource_type") @db.VarChar(80)
  resourceId   String?        @map("resource_id") @db.Uuid
  metadata     Json           @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actor        User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@map("activity_events")
}
