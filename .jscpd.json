{
  "path": ["apps/api/src", "apps/web/src", "apps/mcp/src", "packages/contracts/src"],
  "format": ["typescript", "tsx", "css"],
  "minLines": 8,
  "minTokens": 60,
  "maxLines": 10000,
  "threshold": 3,
  "reporters": ["console"],
  "ignore": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/generated/**",
    "**/dist/**",
    "**/coverage/**",
    "**/node_modules/**"
  ]
}
