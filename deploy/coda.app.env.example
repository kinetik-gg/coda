# Minimal app-only runtime environment. Copy to coda.app.env and replace every placeholder.
NODE_ENV=production
PORT=3000
APP_ORIGIN=https://coda.example.com
TRUSTED_PROXY_CIDRS=127.0.0.1/32
DATABASE_URL=postgresql://user:replace-with-managed-database-password@db.example.com:5432/coda?schema=public&sslmode=require&sslaccept=strict
SESSION_COOKIE_NAME=coda_session
SESSION_TTL_DAYS=30
# SETUP_TOKEN is optional. Leave it unset and Coda generates a one-time setup
# token at first boot, printing it to the container logs (look for the
# "CODA SETUP TOKEN" banner) until owner setup completes. Set an explicit value
# (>=32 characters) to choose the token yourself; this is required when running
# more than one replica, since each replica would otherwise generate its own.
# SETUP_TOKEN=replace-with-a-long-random-one-time-setup-token
S3_ENDPOINT=https://s3.example.com
S3_PUBLIC_ENDPOINT=https://objects.example.com
S3_REGION=replace-with-provider-region
S3_BUCKET=replace-with-private-bucket-name
S3_ACCESS_KEY=replace-with-bucket-scoped-access-key
S3_SECRET_KEY=replace-with-bucket-scoped-secret-key
S3_FORCE_PATH_STYLE=false
LOG_LEVEL=info
