{
  "name": "@coda/api",
  "version": "0.0.2",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-web.cjs",
    "dev": "node scripts/dev.cjs",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --allowOnly=false --exclude dist/**",
    "test:coverage": "vitest run --config ../../vitest.unit.config.ts --coverage",
    "openapi:generate": "tsx src/openapi/generate-openapi.ts",
    "openapi:check": "tsx src/openapi/generate-openapi.ts --check",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1093.0",
    "@aws-sdk/s3-request-presigner": "3.1093.0",
    "@coda/contracts": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/platform-socket.io": "11.1.28",
    "@nestjs/serve-static": "5.0.5",
    "@nestjs/swagger": "11.4.6",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/websockets": "11.1.28",
    "@prisma/client": "7.9.0",
    "argon2": "0.45.1",
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "express-rate-limit": "8.6.0",
    "helmet": "8.3.0",
    "pdf-lib": "1.17.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "prisma": "7.9.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "tsx": "4.23.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.28",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/supertest": "7.2.1",
    "supertest": "7.2.2",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
