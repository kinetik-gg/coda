# Coolify runtime variables for compose.app.yaml. Replace every placeholder in the UI.
CODA_IMAGE=ghcr.io/kinetik-gg/coda@sha256:6109b655fc1a08ed8bf4f8c8cee366d9a0b9859f33d844cda78e96bcfa69a21c
APP_ORIGIN=https://coda.example.com
# "auto" trusts the private subnets Coolify attaches to this container, resolved at
# boot and logged. Single deploy, no network inspection. For a hardened setup,
# replace it with the dedicated resource subnet. Never mix "auto" with an explicit
# list, and never use 0.0.0.0/0 or ::/0.
TRUSTED_PROXY_CIDRS=auto
DATABASE_URL=postgresql://user:replace-with-managed-database-password@db.example.com:5432/coda?schema=public&sslmode=require&sslaccept=strict
SESSION_COOKIE_NAME=coda_session
SESSION_TTL_DAYS=30
# SETUP_TOKEN is optional. Leave it unset and Coda generates a one-time setup
# token at first boot, printing it to the container logs (look for the
# "CODA SETUP TOKEN" banner) until owner setup completes. Set an explicit value
# (>=32 characters) to choose the token yourself; this is required when running
# more than one replica, since each replica would otherwise generate its own.
# SETUP_TOKEN=replace-with-a-long-random-one-time-setup-token
# CONFIG_ENCRYPTION_KEY encrypts the instance-configuration store (AES-256-GCM).
# Generate with `openssl rand -base64 32`. Keep it stable and back it up: the same
# key is required to read previously written config, and Coda refuses to start if
# encrypted config exists but the key is missing or wrong.
# CONFIG_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
S3_ENDPOINT=https://s3.example.com
S3_PUBLIC_ENDPOINT=https://objects.example.com
S3_REGION=replace-with-provider-region
S3_BUCKET=replace-with-private-bucket-name
S3_ACCESS_KEY=replace-with-bucket-scoped-access-key
S3_SECRET_KEY=replace-with-bucket-scoped-secret-key
S3_FORCE_PATH_STYLE=false
LOG_LEVEL=info
# Opt-in sanitized HTTP error detail (name, message, status; stack for 5xx) for
# staging diagnostics. Never logs bodies, headers, cookies, tokens, or queries.
# Keep false in production.
LOG_HTTP_ERROR_DETAIL=false
# METRICS_TOKEN is optional and unset by default, which disables the Prometheus /metrics
# endpoint entirely (it returns 404, not merely 401 unauthorized). Set an explicit value
# (>=16 characters) to enable it, then configure your scraper to send it as an
# `Authorization: Bearer <token>` header. See docs/operations.md.
# METRICS_TOKEN=replace-with-a-long-random-metrics-scrape-token
