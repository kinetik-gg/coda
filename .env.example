NODE_ENV=production
PORT=3000
# Canonical environment template for both compose.yaml and compose.app.yaml.
# Copy the immutable name@sha256 digest from the successful release workflow summary.
CODA_IMAGE=ghcr.io/kinetik-gg/coda@sha256:replace-with-release-manifest-digest
APP_ORIGIN=http://localhost:3000
# Used only by explicit localhost overrides.
CODA_BIND_ADDRESS=127.0.0.1
CODA_APP_PORT=3000
CODA_S3_BIND_ADDRESS=127.0.0.1
CODA_S3_PORT=9000
# Exact source IPs/CIDRs of reverse proxies allowed to supply X-Forwarded-For.
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
# Full-stack only: browser origins allowed to use signed MinIO URLs.
MINIO_CORS_ALLOW_ORIGIN=http://localhost:3000,http://localhost:5173
# Full-stack only. App-only deployments use the managed database URL below instead.
POSTGRES_PASSWORD=replace-with-a-long-random-password
# Keep this password in sync with POSTGRES_PASSWORD and URL-encode it when needed.
DATABASE_URL=postgresql://coda:replace-with-a-long-random-password@postgres:5432/coda?schema=public
# Managed PostgreSQL example (replace every component and require TLS):
# DATABASE_URL=postgresql://user:password@db.example.com:5432/coda?schema=public&sslmode=require&sslaccept=strict
SESSION_COOKIE_NAME=coda_session
SESSION_TTL_DAYS=30
SETUP_TOKEN=replace-with-a-long-random-one-time-setup-token
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=coda
# Full-stack only: MinIO bootstrap credentials are used by MinIO and its one-shot initializer.
MINIO_ROOT_USER=replace-with-a-random-root-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-root-password
MINIO_FORCE_OWNERSHIP_REPAIR=0
# Coda uses this bucket-scoped service account, never the MinIO root account.
S3_ACCESS_KEY=replace-with-a-random-service-access-key
S3_SECRET_KEY=replace-with-a-long-random-service-secret-key
S3_FORCE_PATH_STYLE=true
PDF_MAX_BYTES=262144000
PDF_WORKER_MAX_OLD_GENERATION_MB=512
# The transport limit covers 5,000,000 UTF-8 Fountain characters plus JSON overhead.
SCREENPLAY_REQUEST_MAX_BYTES=20016384
SCREENPLAY_BODY_MAX_CONCURRENT=4
SCREENPLAY_PREAUTH_WINDOW_MS=60000
SCREENPLAY_PREAUTH_MAX_PER_CLIENT=120
SCREENPLAY_PREAUTH_MAX_GLOBAL=1200
SCREENPLAY_BODY_TIMEOUT_MS=30000
SCREENPLAY_MAX_DOCUMENTS_PER_OWNER=250
SCREENPLAY_MAX_SOURCE_BYTES_PER_OWNER=262144000
ASSET_MAX_BYTES=2147483648
STORAGE_PENDING_MAX_OBJECTS=20
STORAGE_PENDING_MAX_BYTES=5368709120
STORAGE_PENDING_INSTANCE_MAX_OBJECTS=1000
STORAGE_PENDING_INSTANCE_MAX_BYTES=21474836480
STORAGE_UPLOAD_RETENTION_HOURS=24
SIGNED_READ_TTL_SECONDS=300
SIGNED_UPLOAD_TTL_SECONDS=900
LOG_LEVEL=info
# The destructive demo reset is opt-in and restricted to loopback services.
# Never set this in a shared or production environment.
# CODA_DEMO_RESET=true
