# Coolify runtime variables for compose.minio.yaml. Replace every placeholder in the UI.
# This standalone stack defines no CODA_IMAGE, DATABASE_URL, or application variables; the
# Coda application resource carries those. Mark every credential as a sensitive runtime
# variable and disable its Build Variable option.
MINIO_ROOT_USER=replace-with-a-random-root-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-root-password
MINIO_CORS_ALLOW_ORIGIN=https://coda.example.com
MINIO_FORCE_OWNERSHIP_REPAIR=0
S3_BUCKET=coda
S3_ACCESS_KEY=replace-with-a-random-bucket-scoped-access-key
S3_SECRET_KEY=replace-with-a-long-random-bucket-scoped-secret-key
