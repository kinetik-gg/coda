# Coolify runtime variables for compose.full.yaml. Replace every placeholder in the UI.
CODA_IMAGE=ghcr.io/kinetik-gg/coda@sha256:replace-with-release-manifest-digest
APP_ORIGIN=https://coda.example.com
# Safe bootstrap: replace with the dedicated resource subnet before adding the public domain.
TRUSTED_PROXY_CIDRS=127.0.0.1/32
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://coda:replace-with-the-url-encoded-postgres-password@postgres:5432/coda?schema=public
SESSION_COOKIE_NAME=coda_session
SESSION_TTL_DAYS=30
# SETUP_TOKEN is optional. Leave it unset and Coda generates a one-time setup
# token at first boot, printing it to the container logs (look for the
# "CODA SETUP TOKEN" banner) until owner setup completes. Set an explicit value
# (>=32 characters) to choose the token yourself; this is required when running
# more than one replica, since each replica would otherwise generate its own.
# SETUP_TOKEN=replace-with-a-long-random-one-time-setup-token
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=https://objects.example.com
S3_REGION=us-east-1
S3_BUCKET=coda
MINIO_CORS_ALLOW_ORIGIN=https://coda.example.com
MINIO_ROOT_USER=replace-with-a-random-root-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-root-password
S3_ACCESS_KEY=replace-with-a-random-bucket-scoped-access-key
S3_SECRET_KEY=replace-with-a-long-random-bucket-scoped-secret-key
S3_FORCE_PATH_STYLE=true
LOG_LEVEL=info
