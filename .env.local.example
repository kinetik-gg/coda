NODE_ENV=development
PORT=3000
APP_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://coda:replace-with-the-local-postgres-password@127.0.0.1:5432/coda?schema=public
SESSION_COOKIE_NAME=coda_session
SESSION_TTL_DAYS=30
# Optional in development. Set it to exercise production-style first-run setup protection.
# SETUP_TOKEN=replace-with-a-long-random-one-time-setup-token
S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=coda
S3_ACCESS_KEY=replace-with-the-local-service-access-key
S3_SECRET_KEY=replace-with-the-local-service-secret-key
S3_FORCE_PATH_STYLE=true
PDF_MAX_BYTES=262144000
ASSET_MAX_BYTES=2147483648
SIGNED_READ_TTL_SECONDS=300
SIGNED_UPLOAD_TTL_SECONDS=900
LOG_LEVEL=debug
