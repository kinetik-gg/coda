{
  "name": "@coda/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --exclude dist/**",
    "test:coverage": "vitest run --allowOnly=false --coverage --exclude dist/** --coverage.thresholds.lines=80 --coverage.thresholds.statements=80 --coverage.thresholds.branches=80 --coverage.thresholds.functions=80"
  },
  "dependencies": {
    "@coda/contracts": "workspace:*",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@fontsource/inter": "5.2.8",
    "@fontsource/space-mono": "5.2.8",
    "@hookform/resolvers": "5.2.2",
    "@phosphor-icons/react": "2.1.10",
    "@tanstack/react-query": "5.90.20",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.13.12",
    "pdfjs-dist": "5.4.530",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "7.71.1",
    "socket.io-client": "4.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "jsdom": "27.4.0",
    "typescript": "5.9.3",
    "vite": "7.3.5",
    "vitest": "4.1.10"
  }
}
